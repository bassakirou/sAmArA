{
  "name": "sAmArA-monorepo",
  "private": true,
  "scripts": {
    "install": "pnpm -r install",
    "dev:api": "pnpm --filter api dev",
    "dev:front": "pnpm --filter front dev",
    "dev:admin": "pnpm --filter admin dev",
    "dev:websockets": "cd packages/api && php artisan websockets:serve",
    "dev:apps": "concurrently -c \"cyan,magenta,yellow\" \"pnpm dev:front\" \"pnpm dev:admin\" \"pnpm dev:websockets\"",
    "dev": "pnpm -r --parallel dev"
  },
  "devDependencies": {
    "pnpm": "^8.0.0"
  }
}
